cxx_library(
    name = "sha1",
    srcs = [":zeromq-src[external/sha1/sha1.c]"],
    header_namespace = "",
    compiler_flags = [
        "-DZMQ_BUILD_TESTS=OFF",
        "-DZMQ_BUILD_DRAFT_API=1",
        "-DZMQ_STATIC=1",
        "-DZMQ_USE_BUILTIN_SHA1=1",
        "-DZMQ_HAVE_WS=1",
        "-DZMQ_CACHELINE_SIZE=64",
    ],
    preferred_linkage = "static",
    visibility = ["PUBLIC"],
)

